# Chave mestra para descriptografia das credenciais
# Gerada automaticamente pelo setup.js - NÃO altere manualmente
MASTER_KEY=

# Porta do servidor (padrão: 3000)
PORT=3000

# Host local para rodar atras do Nginx
HOST=127.0.0.1

# Telefone de atendimento exibido no rodapé
TELEFONE_ATENDIMENTO=

# Origem pública permitida para acesso à API
PUBLIC_ORIGIN=https://boleto.seegfibras.com.br
